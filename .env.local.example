# Copy this file to `.env.local` and fill in your free Supabase project values.
# The leaderboard is OPTIONAL decoration — the game works fully offline without these.
# Vite only exposes vars prefixed with VITE_ to the client.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
