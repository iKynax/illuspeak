{
  "name": "illuspeak",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile web app for the Illuspeak art event (Jul 18-26 @GMBB L5).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "assets": "node scripts/process-assets.mjs",
    "logos": "node scripts/process-logos.mjs",
    "qr": "node --experimental-strip-types scripts/generate-qr.mjs"
  },
  "dependencies": {
    "@fontsource/lilita-one": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@supabase/supabase-js": "^2.108.2",
    "html-to-image": "^1.11.13",
    "jsqr": "^1.4.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-zoom-pan-pinch": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}
